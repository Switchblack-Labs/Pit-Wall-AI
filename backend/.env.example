# Pit Wall AI Backend — example environment configuration.
# Copy to `.env` and fill in as needed. ALL values are optional: with none set,
# the backend runs fully offline using the deterministic "echo" LLM provider.

# --- App ---
APP_NAME="Pit Wall AI Backend"
APP_VERSION="1.0.0"
DEBUG=true
HOST=0.0.0.0
PORT=8000
WS_HEARTBEAT_INTERVAL=30

# --- LLM provider selection ---
# auto (default) | watsonx | replicate | ollama | echo
LLM_PROVIDER=auto
# Ordered fallback used by auto-selection and on provider error.
LLM_FALLBACK_ORDER=watsonx,replicate,ollama,echo

# --- IBM watsonx.ai (Granite) ---
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL=ibm/granite-3-3-8b-instruct

# --- Replicate-hosted Granite ---
REPLICATE_API_TOKEN=
REPLICATE_MODEL=ibm-granite/granite-3.3-8b-instruct

# --- Local Ollama (no key required) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=granite3.3:8b

# --- Legacy (kept for backward compatibility; not required) ---
GRANITE_API_KEY=
GRANITE_MODEL=ibm-granite/granite-3.3-8b-instruct

# --- FIA RAG ---
# Number of chunks retrieved per query.
RAG_RETRIEVAL_K=4

# --- LangFlow (optional orchestration server) ---
# Leave empty to run the in-process Python pipelines (the source of truth).
LANGFLOW_URL=
LANGFLOW_API_KEY=

# --- Telemetry / TORCS ---
MOCK_TELEMETRY_MODE=true
TELEMETRY_SOURCE=mock
